{
  "name": "chatpdm-root",
  "version": "0.1.0",
  "private": true,
  "description": "Root orchestration for the ChatPDM repository.",
  "scripts": {
    "bootstrap": "npm run install:frontend && npm run install:backend",
    "install:frontend": "npm install --prefix ./frontend",
    "install:backend": "npm install --prefix ./backend",
    "dev": "concurrently -k -n frontend,backend -c cyan,green \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "npm --prefix ./frontend run start",
    "dev:backend": "npm --prefix ./backend run dev",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "npm --prefix ./frontend run build",
    "build:backend": "npm --prefix ./backend run build",
    "check": "npm run verify:dependency-discipline && npm run build",
    "verify:dependency-discipline": "node ./scripts/verify-dependency-discipline.js",
    "validate:policy-governance": "node ./scripts/validate-policy-governance.js",
    "validate:policy-lifecycle-contract": "npm --prefix ./frontend run generate:policy-surface",
    "validate:policy-surface-split": "npm --prefix ./frontend run validate:policy-surface-split",
    "validate:phase-1-mapping": "node ./backend/scripts/validate-phase-1-mapping.js",
    "validate:register-divergence": "npm --prefix ./backend run validate:register-divergence",
    "validate:registers": "node ./scripts/validate-registers.js",
    "verify:overlap-ci-enforcement": "node ./scripts/verify-overlap-ci-enforcement.js",
    "diff:registers": "node ./scripts/diff-registers.js",
    "diff:concepts": "node ./scripts/diff-concepts.js",
    "scan:ai-governance": "node ./scripts/ai-governance-scan.js",
    "replay:ai-violations": "node ./scripts/replay-ai-violations.js",
    "capture:ai-violation": "node ./scripts/ai-governance-scan.js --capture",
    "check:commit-intent": "node ./scripts/check-commit-intent.js",
    "check:register-edit-discipline": "node ./scripts/check-register-edit-discipline.js",
    "lint:md": "markdownlint-cli2 \"*.md\" \"backend/**/*.md\" \"data/**/*.md\" \"deploy/**/*.md\" \"docs/**/*.md\" \"frontend/**/*.md\" \"tests/**/*.md\" \"!node_modules/**\" \"!backend/node_modules/**\" \"!frontend/node_modules/**\" \"!frontend/dist/**\""
  },
  "devDependencies": {
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "concurrently": "^9.2.1",
    "markdownlint-cli2": "^0.22.0"
  }
}
