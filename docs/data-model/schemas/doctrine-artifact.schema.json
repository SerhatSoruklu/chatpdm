{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chatpdm.local/docs/data-model/schemas/doctrine-artifact.schema.json",
  "title": "Legal Argument Validator DoctrineArtifact Schema",
  "description": "Strict JSON Schema for immutable retained doctrine artifact records used by validation runs.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifactId",
    "hash",
    "version",
    "packageId",
    "storageKey",
    "manifest",
    "retainedAt",
    "retentionStatus",
    "createdAt"
  ],
  "properties": {
    "artifactId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "packageId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "storageKey": {
      "type": "string",
      "minLength": 1
    },
    "manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packageId",
        "version",
        "jurisdiction",
        "practiceArea",
        "coreConceptsReferenced",
        "packageConceptsDeclared",
        "authoritySets",
        "synonymTable",
        "constraints"
      ],
      "properties": {
        "packageId": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "jurisdiction": {
          "type": "string",
          "minLength": 1
        },
        "practiceArea": {
          "type": "string",
          "minLength": 1
        },
        "coreConceptsReferenced": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "packageConceptsDeclared": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "authoritySets": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "synonymTable": {
          "type": "string",
          "minLength": 1
        },
        "constraints": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "retainedAt": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "retentionStatus": {
      "type": "string",
      "enum": [
        "pending_retention",
        "retained",
        "retention_failed",
        "unavailable"
      ]
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
