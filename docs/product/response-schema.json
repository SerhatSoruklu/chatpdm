{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chatpdm.local/docs/product/response-schema.json",
  "title": "ChatPDM v1 Product Response Schema",
  "description": "Strict JSON Schema for ChatPDM v1 product response payloads. This schema covers product outcomes only and does not include API or system error envelopes.",
  "$comment": "This schema validates response shape only. Governance-scope policy for authority, power, and legitimacy is defined in authored concept packets and supporting product documentation.",
  "oneOf": [
    {
      "$ref": "#/$defs/conceptMatchResponse"
    },
    {
      "$ref": "#/$defs/rejectedConceptResponse"
    },
    {
      "$ref": "#/$defs/vocabularyDetectedResponse"
    },
    {
      "$ref": "#/$defs/noExactMatchResponse"
    },
    {
      "$ref": "#/$defs/invalidQueryResponse"
    },
    {
      "$ref": "#/$defs/unsupportedQueryTypeResponse"
    },
    {
      "$ref": "#/$defs/ambiguousMatchResponse"
    },
    {
      "$ref": "#/$defs/comparisonResponse"
    }
  ],
  "$defs": {
    "stringValue": {
      "type": "string",
      "minLength": 1
    },
    "contractVersionString": {
      "type": "string",
      "minLength": 1,
      "pattern": "^v\\d+\\.\\d+$"
    },
    "datedVersionString": {
      "type": "string",
      "minLength": 1,
      "pattern": "^\\d{4}-\\d{2}-\\d{2}\\.v\\d+$"
    },
    "conceptSetVersionString": {
      "type": "string",
      "minLength": 1,
      "pattern": "^\\d{8}\\.\\d+$"
    },
    "productQueryType": {
      "type": "string",
      "enum": [
        "exact_concept_query",
        "canonical_id_query",
        "ambiguity_query",
        "comparison_query",
        "relation_query",
        "role_or_actor_query",
        "unsupported_complex_query",
        "invalid_query"
      ]
    },
    "interpretationObject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "interpretationType",
        "message"
      ],
      "properties": {
        "interpretationType": {
          "type": "string",
          "enum": [
            "comparison_not_supported",
            "relation_not_supported",
            "role_or_actor_not_supported",
            "ambiguous_selection",
            "validation_blocked",
            "unsupported_complex",
            "canonical_lookup_not_found",
            "exact_concept_not_found",
            "visible_only_public_concept",
            "explicitly_rejected_concept",
            "invalid_query",
            "out_of_scope",
            "scoped_clarification",
            "unresolved_domain",
            "unsupported_semantic_bridge",
            "domain_boundary_violation",
            "causal_overreach"
          ]
        },
        "message": {
          "$ref": "#/$defs/stringValue"
        },
        "baseConcept": {
          "$ref": "#/$defs/stringValue"
        },
        "concepts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/stringValue"
          }
        },
        "relationTerm": {
          "$ref": "#/$defs/stringValue"
        },
        "actorTerm": {
          "$ref": "#/$defs/stringValue"
        },
        "targetConceptId": {
          "$ref": "#/$defs/stringValue"
        },
        "concept": {
          "$ref": "#/$defs/stringValue"
        },
        "domain": {
          "$ref": "#/$defs/stringValue"
        }
      }
    },
    "contextObject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "appliesTo"
      ],
      "properties": {
        "label": {
          "$ref": "#/$defs/stringValue"
        },
        "appliesTo": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/stringValue"
          }
        }
      }
    },
    "sourceObject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "type",
        "usedFor"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/stringValue"
        },
        "label": {
          "$ref": "#/$defs/stringValue"
        },
        "type": {
          "type": "string",
          "enum": [
            "dictionary",
            "book",
            "paper",
            "law",
            "article",
            "internal"
          ]
        },
        "usedFor": {
          "$ref": "#/$defs/stringValue"
        }
      }
    },
    "relatedConceptObject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "conceptId",
        "title",
        "relationType"
      ],
      "properties": {
        "conceptId": {
          "$ref": "#/$defs/stringValue"
        },
        "title": {
          "$ref": "#/$defs/stringValue"
        },
        "relationType": {
          "type": "string",
          "enum": [
            "see_also",
            "prerequisite",
            "extension",
            "contrast"
          ]
        }
      }
    },
    "readingRegisterCanonicalBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "conceptId",
        "conceptVersion",
        "canonicalHash"
      ],
      "properties": {
        "conceptId": {
          "$ref": "#/$defs/stringValue"
        },
        "conceptVersion": {
          "type": "integer"
        },
        "canonicalHash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "readingRegisterFields": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "shortDefinition",
        "coreMeaning",
        "fullDefinition"
      ],
      "properties": {
        "shortDefinition": {
          "$ref": "#/$defs/stringValue"
        },
        "coreMeaning": {
          "$ref": "#/$defs/stringValue"
        },
        "fullDefinition": {
          "$ref": "#/$defs/stringValue"
        }
      }
    },
    "readingRegisterValidationReason": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code"
      ],
      "properties": {
        "code": {
          "$ref": "#/$defs/stringValue"
        },
        "field": {
          "$ref": "#/$defs/stringValue"
        },
        "detail": {
          "$ref": "#/$defs/stringValue"
        }
      }
    },
    "readingRegisterModeValidation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "reasons"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "available",
            "rejected"
          ]
        },
        "reasons": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/readingRegisterValidationReason"
          }
        }
      }
    },
    "readingRegisterValidation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "availableModes",
        "modes"
      ],
      "properties": {
        "availableModes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "standard",
              "simplified",
              "formal"
            ]
          }
        },
        "modes": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "standard",
            "simplified",
            "formal"
          ],
          "properties": {
            "standard": {
              "$ref": "#/$defs/readingRegisterModeValidation"
            },
            "simplified": {
              "$ref": "#/$defs/readingRegisterModeValidation"
            },
            "formal": {
              "$ref": "#/$defs/readingRegisterModeValidation"
            }
          }
        }
      }
    },
    "readingRegistersObject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "readOnly",
        "canonicalBinding",
        "validation",
        "standard"
      ],
      "properties": {
        "readOnly": {
          "const": true
        },
        "canonicalBinding": {
          "$ref": "#/$defs/readingRegisterCanonicalBinding"
        },
        "validation": {
          "$ref": "#/$defs/readingRegisterValidation"
        },
        "standard": {
          "$ref": "#/$defs/readingRegisterFields"
        },
        "simplified": {
          "$ref": "#/$defs/readingRegisterFields"
        },
        "formal": {
          "$ref": "#/$defs/readingRegisterFields"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "validation": {
                "properties": {
                  "availableModes": {
                    "contains": {
                      "const": "standard"
                    }
                  }
                }
              }
            }
          },
          "then": {
            "required": [
              "standard"
            ]
          },
          "else": {
            "not": {
              "required": [
                "standard"
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "validation": {
                "properties": {
                  "availableModes": {
                    "contains": {
                      "const": "simplified"
                    }
                  }
                }
              }
            }
          },
          "then": {
            "required": [
              "simplified"
            ]
          },
          "else": {
            "not": {
              "required": [
                "simplified"
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "validation": {
                "properties": {
                  "availableModes": {
                    "contains": {
                      "const": "formal"
                    }
                  }
                }
              }
            }
          },
          "then": {
            "required": [
              "formal"
            ]
          },
          "else": {
            "not": {
              "required": [
                "formal"
              ]
            }
          }
        }
      ]
    },
    "nullableV3Status": {
      "enum": [
        "not_applicable",
        "incomplete",
        "passing",
        null
      ]
    },
    "nullableRelationStatus": {
      "enum": [
        "not_applicable",
        "incomplete",
        "passing",
        null
      ]
    },
    "nullableLawStatus": {
      "enum": [
        "not_applicable",
        "failing",
        "warning_only",
        "passing",
        null
      ]
    },
    "nullableEnforcementStatus": {
      "enum": [
        "passing",
        "warning_only",
        "blocked",
        null
      ]
    },
    "nullableValidationState": {
      "enum": [
        "language_invalid",
        "language_valid",
        "structurally_incomplete",
        "fully_validated",
        null
      ]
    },
    "nullableSystemValidationState": {
      "enum": [
        "language_invalid",
        "structurally_incomplete",
        "law_blocked",
        "law_warning_only",
        "law_validated",
        "language_valid",
        null
      ]
    },
    "governanceStateTraceObject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "conceptId",
        "validatorSource",
        "unavailableReason",
        "relationSource",
        "lawSource",
        "relationDataPresent",
        "dataSource"
      ],
      "properties": {
        "conceptId": {
          "$ref": "#/$defs/stringValue"
        },
        "validatorSource": {
          "enum": [
            "validator_artifact",
            "unavailable"
          ]
        },
        "unavailableReason": {
          "enum": [
            "artifact_missing",
            "artifact_invalid",
            "concept_state_missing",
            null
          ]
        },
        "relationSource": {
          "enum": [
            "authored",
            "fallback",
            "none",
            null
          ]
        },
        "lawSource": {
          "enum": [
            "authored",
            "fallback",
            "none",
            null
          ]
        },
        "relationDataPresent": {
          "type": "boolean"
        },
        "dataSource": {
          "enum": [
            "authored_relation_packets",
            "default_seed_relations",
            "none",
            null
          ]
        }
      }
    },
    "governanceStateObject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "available",
        "validationState",
        "v3Status",
        "relationStatus",
        "lawStatus",
        "enforcementStatus",
        "systemValidationState",
        "isBlocked",
        "isStructurallyIncomplete",
        "isFullyValidated",
        "isActionable",
        "trace"
      ],
      "properties": {
        "source": {
          "enum": [
            "validator_artifact",
            "unavailable"
          ]
        },
        "available": {
          "type": "boolean"
        },
        "validationState": {
          "$ref": "#/$defs/nullableValidationState"
        },
        "v3Status": {
          "$ref": "#/$defs/nullableV3Status"
        },
        "relationStatus": {
          "$ref": "#/$defs/nullableRelationStatus"
        },
        "lawStatus": {
          "$ref": "#/$defs/nullableLawStatus"
        },
        "enforcementStatus": {
          "$ref": "#/$defs/nullableEnforcementStatus"
        },
        "systemValidationState": {
          "$ref": "#/$defs/nullableSystemValidationState"
        },
        "isBlocked": {
          "type": "boolean"
        },
        "isStructurallyIncomplete": {
          "type": "boolean"
        },
        "isFullyValidated": {
          "type": "boolean"
        },
        "isActionable": {
          "type": "boolean"
        },
        "trace": {
          "$ref": "#/$defs/governanceStateTraceObject"
        }
      }
    },
    "suggestionObject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "conceptId",
        "title",
        "reason"
      ],
      "properties": {
        "conceptId": {
          "$ref": "#/$defs/stringValue"
        },
        "title": {
          "$ref": "#/$defs/stringValue"
        },
        "reason": {
          "type": "string",
          "enum": [
            "similar_term",
            "broader_topic",
            "related_concept"
          ]
        }
      }
    },
    "candidateObject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "conceptId",
        "title",
        "shortDefinition",
        "basis"
      ],
      "properties": {
        "conceptId": {
          "$ref": "#/$defs/stringValue"
        },
        "title": {
          "$ref": "#/$defs/stringValue"
        },
        "shortDefinition": {
          "$ref": "#/$defs/stringValue"
        },
        "basis": {
          "type": "string",
          "enum": [
            "shared_alias",
            "normalized_overlap",
            "author_defined_disambiguation"
          ]
        }
      }
    },
    "conceptMatchResolution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method",
        "conceptId",
        "conceptVersion"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "exact_alias",
            "normalized_alias",
            "canonical_id"
          ]
        },
        "conceptId": {
          "$ref": "#/$defs/stringValue"
        },
        "conceptVersion": {
          "type": "integer"
        }
      }
    },
    "noExactMatchResolution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "no_exact_match",
            "out_of_scope"
          ]
        }
      }
    },
    "ambiguousMatchResolution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "ambiguous_alias",
            "ambiguous_normalized_alias",
            "author_defined_disambiguation"
          ]
        }
      }
    },
    "invalidQueryResolution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method"
      ],
      "properties": {
        "method": {
          "const": "invalid_query"
        }
      }
    },
    "unsupportedQueryTypeResolution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method"
      ],
      "properties": {
        "method": {
          "const": "unsupported_query_type"
        }
      }
    },
    "rejectedConceptResolution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method",
        "conceptId"
      ],
      "properties": {
        "method": {
          "const": "rejection_registry"
        },
        "conceptId": {
          "$ref": "#/$defs/stringValue"
        }
      }
    },
    "vocabularyDetectedResolution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method"
      ],
      "properties": {
        "method": {
          "const": "vocabulary_guard"
        }
      }
    },
    "rejectionObject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "decisionType",
        "finality"
      ],
      "properties": {
        "status": {
          "const": "REJECTED"
        },
        "decisionType": {
          "const": "STRUCTURAL_REJECTION"
        },
        "finality": {
          "type": "boolean"
        }
      }
    },
    "vocabularyClassificationType": {
      "type": "string",
      "enum": [
        "legal_term",
        "informal_term",
        "ambiguous_term"
      ]
    },
    "vocabularyRelationsObject": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "closestConcept": {
          "$ref": "#/$defs/stringValue"
        },
        "contrastWith": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/stringValue"
          }
        },
        "relatedConcepts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/stringValue"
          }
        }
      }
    },
    "vocabularySystemFlagsObject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "isCoreConcept",
        "usableInResolver",
        "reasoningAllowed"
      ],
      "properties": {
        "isCoreConcept": {
          "const": false
        },
        "usableInResolver": {
          "const": false
        },
        "reasoningAllowed": {
          "const": false
        }
      }
    },
    "vocabularyClassificationResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input",
        "normalizedInput",
        "matched",
        "term",
        "classification",
        "relations",
        "systemFlags"
      ],
      "properties": {
        "input": {
          "$ref": "#/$defs/stringValue"
        },
        "normalizedInput": {
          "$ref": "#/$defs/stringValue"
        },
        "matched": {
          "type": "boolean"
        },
        "term": {
          "type": [
            "string",
            "null"
          ]
        },
        "classification": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "legal_term",
            "informal_term",
            "ambiguous_term",
            null
          ]
        },
        "relations": {
          "oneOf": [
            {
              "$ref": "#/$defs/vocabularyRelationsObject"
            },
            {
              "type": "null"
            }
          ]
        },
        "systemFlags": {
          "$ref": "#/$defs/vocabularySystemFlagsObject"
        }
      }
    },
    "answerObject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "itemType",
        "title",
        "shortDefinition",
        "coreMeaning",
        "fullDefinition",
        "governanceState",
        "registers",
        "contexts",
        "sources",
        "relatedConcepts"
      ],
      "properties": {
        "itemType": {
          "const": "core_concept"
        },
        "title": {
          "$ref": "#/$defs/stringValue"
        },
        "shortDefinition": {
          "$ref": "#/$defs/stringValue"
        },
        "coreMeaning": {
          "$ref": "#/$defs/stringValue"
        },
        "fullDefinition": {
          "$ref": "#/$defs/stringValue"
        },
        "governanceState": {
          "$ref": "#/$defs/governanceStateObject"
        },
        "registers": {
          "$ref": "#/$defs/readingRegistersObject"
        },
        "contexts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/contextObject"
          }
        },
        "sources": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/sourceObject"
          }
        },
        "relatedConcepts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/relatedConceptObject"
          }
        }
      }
    },
    "comparisonAxisObject": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "axis",
            "A",
            "B"
          ],
          "properties": {
            "axis": {
              "$ref": "#/$defs/stringValue"
            },
            "A": {
              "$ref": "#/$defs/stringValue"
            },
            "B": {
              "$ref": "#/$defs/stringValue"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "axis",
            "statement"
          ],
          "properties": {
            "axis": {
              "$ref": "#/$defs/stringValue"
            },
            "statement": {
              "$ref": "#/$defs/stringValue"
            }
          }
        }
      ]
    },
    "comparisonObject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "conceptA",
        "conceptB",
        "axes"
      ],
      "properties": {
        "conceptA": {
          "$ref": "#/$defs/stringValue"
        },
        "conceptB": {
          "$ref": "#/$defs/stringValue"
        },
        "axes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/comparisonAxisObject"
          }
        }
      }
    },
    "conceptMatchResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "query",
        "normalizedQuery",
        "contractVersion",
        "normalizerVersion",
        "matcherVersion",
        "conceptSetVersion",
        "queryType",
        "interpretation",
        "resolution",
        "answer"
      ],
      "properties": {
        "type": {
          "const": "concept_match"
        },
        "query": {
          "$ref": "#/$defs/stringValue"
        },
        "normalizedQuery": {
          "$ref": "#/$defs/stringValue"
        },
        "contractVersion": {
          "$ref": "#/$defs/contractVersionString"
        },
        "normalizerVersion": {
          "$ref": "#/$defs/datedVersionString"
        },
        "matcherVersion": {
          "$ref": "#/$defs/datedVersionString"
        },
        "conceptSetVersion": {
          "$ref": "#/$defs/conceptSetVersionString"
        },
        "queryType": {
          "type": "string",
          "enum": [
            "exact_concept_query",
            "canonical_id_query"
          ]
        },
        "interpretation": {
          "type": "null"
        },
        "resolution": {
          "$ref": "#/$defs/conceptMatchResolution"
        },
        "answer": {
          "$ref": "#/$defs/answerObject"
        }
      }
    },
    "comparisonResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "mode",
        "query",
        "normalizedQuery",
        "contractVersion",
        "normalizerVersion",
