{
  "name": "@chatpdm/backend",
  "version": "1.0.0",
  "description": "Express shell for the ChatPDM workspace.",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon --watch src --watch scripts --ext js,json src/server.js",
    "start": "node src/server.js",
    "build": "npm run check",
    "check": "node scripts/verify-shell.js && node scripts/verify-resolver.js && node scripts/verify-feedback.js",
    "pressure:semantic": "node ../tests/runtime/run-query-stress.js",
    "test": "node scripts/verify-resolver.js && node scripts/verify-feedback.js"
  },
  "keywords": [
    "chatpdm",
    "express",
    "deterministic",
    "api"
  ],
  "author": "",
  "license": "UNLICENSED",
  "type": "commonjs",
  "dependencies": {
    "ajv": "^8.18.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "mongoose": "^9.3.3"
  },
  "devDependencies": {
    "mongodb-memory-server": "^10.4.1",
    "nodemon": "^3.1.10"
  }
}
