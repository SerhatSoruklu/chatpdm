{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chatpdm.local/schemas/military-constraint-authority-graph.schema.json",
  "title": "Military Constraint Authority Graph",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "authorityGraphId",
    "version",
    "status",
    "levels",
    "delegationEdges"
  ],
  "properties": {
    "authorityGraphId": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "ACTIVE",
        "INACTIVE",
        "SUPERSEDED"
      ]
    },
    "levels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "levelId",
          "rank"
        ],
        "properties": {
          "levelId": {
            "type": "string",
            "minLength": 1
          },
          "rank": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1000000
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "delegationEdges": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "edgeId",
          "fromLevelId",
          "toLevelId",
          "actionKinds",
          "forceLevels"
        ],
        "properties": {
          "edgeId": {
            "type": "string",
            "minLength": 1
          },
          "fromLevelId": {
            "type": "string",
            "minLength": 1
          },
          "toLevelId": {
            "type": "string",
            "minLength": 1
          },
          "actionKinds": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "forceLevels": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "enum": [
                "NON_LETHAL",
                "LETHAL",
                "DEADLY"
              ]
            }
          },
          "scope": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "missionTypes": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "domains": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "enum": [
                    "LAND",
                    "AIR",
                    "MARITIME",
                    "CYBER",
                    "SPACE",
                    "MULTI_DOMAIN"
                  ]
                }
              }
            }
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
