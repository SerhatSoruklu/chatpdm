{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chatpdm.local/schemas/source-clause.schema.json",
  "title": "Military Source Clause",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "clauseId",
    "sourceId",
    "locator",
    "jurisdiction",
    "layer",
    "clauseType",
    "rawText",
    "normalizedText",
    "machineCandidate",
    "ambiguityStatus",
    "reviewStatus",
    "reviewNotes",
    "provenance"
  ],
  "properties": {
    "clauseId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Z0-9-]+$"
    },
    "sourceId": {
      "type": "string",
      "minLength": 1
    },
    "locator": {
      "type": "string",
      "minLength": 1
    },
    "jurisdiction": {
      "type": "string",
      "minLength": 1
    },
    "layer": {
      "type": "string",
      "enum": [
        "LEGAL_FLOOR",
        "POLICY_OVERLAY",
        "EXAMPLE_ONLY"
      ]
    },
    "clauseType": {
      "type": "string",
      "enum": [
        "PROHIBITION",
        "REQUIREMENT",
        "AUTHORITY_GATE",
        "DELEGATION",
        "CAVEAT",
        "DEFINITIONAL"
      ]
    },
    "rawText": {
      "type": "string",
      "minLength": 1
    },
    "normalizedText": {
      "type": "string",
      "minLength": 1
    },
    "machineCandidate": {
      "type": "boolean"
    },
    "ambiguityStatus": {
      "type": "string",
      "enum": [
        "CLEAR",
        "RESOLVED",
        "AMBIGUOUS",
        "OPEN",
        "UNRESOLVED"
      ]
    },
    "reviewStatus": {
      "type": "string",
      "enum": [
        "DRAFT",
        "REVIEWED",
        "APPROVED",
        "COMPILATION_READY",
        "REJECTED"
      ]
    },
    "reviewNotes": {
      "type": "string"
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "derivationType",
        "transformationNotes",
        "parentClauseIds"
      ],
      "properties": {
        "derivationType": {
          "type": "string",
          "enum": [
            "DIRECT",
            "INTERPRETED",
            "COMPOSED",
            "ILLUSTRATIVE"
          ]
        },
        "transformationNotes": {
          "type": "string",
          "minLength": 1
        },
        "parentClauseIds": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "compilationHint": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "stage": {
          "type": "string",
          "enum": [
            "ADMISSIBILITY",
            "LEGAL_FLOOR",
            "POLICY_OVERLAY"
          ]
        },
        "priority": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000000
        },
        "effect": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "decision",
            "reasonCode"
          ],
          "properties": {
            "decision": {
              "type": "string",
              "enum": [
                "ALLOWED",
                "REFUSED",
                "REFUSED_INCOMPLETE"
              ]
            },
            "reasonCode": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "scope": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "jurisdiction": {
              "type": "string",
              "minLength": 1
            },
            "domains": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "enum": [
                  "LAND",
                  "AIR",
                  "MARITIME",
                  "CYBER",
                  "SPACE",
                  "MULTI_DOMAIN"
                ]
              }
            },
            "missionTypes": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "actionKinds": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "authority": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "minimumLevelId": {
              "type": "string",
              "minLength": 1
            },
            "requiresExplicitDelegation": {
              "type": "boolean"
            },
            "delegationEdgeIds": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "requiredFacts": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_]+(?:\\.[A-Za-z0-9_]+)*$"
          }
        },
        "predicate": {
          "$ref": "./military-constraint-predicate.schema.json"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "layer": {
            "const": "EXAMPLE_ONLY"
          }
        }
      },
      "then": {
        "properties": {
          "provenance": {
            "type": "object",
            "properties": {
              "derivationType": {
                "const": "ILLUSTRATIVE"
              }
            }
          },
          "machineCandidate": {
            "const": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "ambiguityStatus": {
            "enum": [
              "AMBIGUOUS",
              "OPEN",
              "UNRESOLVED"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "machineCandidate": {
            "const": false
          }
        },
        "not": {
          "properties": {
            "reviewStatus": {
              "const": "COMPILATION_READY"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "machineCandidate": {
            "const": true
          }
        }
      },
      "then": {
        "properties": {
          "provenance": {
            "type": "object",
            "properties": {
              "derivationType": {
                "enum": [
                  "DIRECT",
                  "INTERPRETED",
                  "COMPOSED"
                ]
              }
            }
          },
          "ambiguityStatus": {
            "enum": [
              "CLEAR",
              "RESOLVED"
            ]
          },
          "reviewStatus": {
            "enum": [
              "APPROVED",
              "COMPILATION_READY"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "provenance": {
            "type": "object",
            "properties": {
              "derivationType": {
                "const": "COMPOSED"
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "provenance": {
            "type": "object",
            "properties": {
              "parentClauseIds": {
                "type": "array",
                "minItems": 1
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "provenance": {
            "type": "object",
            "properties": {
              "derivationType": {
                "enum": [
                  "DIRECT",
                  "INTERPRETED",
                  "ILLUSTRATIVE"
                ]
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "provenance": {
            "type": "object",
            "properties": {
              "parentClauseIds": {
                "type": "array",
                "maxItems": 0
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "required": [
          "compilationHint"
        ],
        "properties": {
          "compilationHint": {
            "type": "object",
            "required": [
              "authority"
            ],
            "properties": {
              "authority": {
                "type": "object",
                "required": [
                  "requiresExplicitDelegation"
                ],
                "properties": {
                  "requiresExplicitDelegation": {
                    "const": true
                  }
                }
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "compilationHint": {
            "type": "object",
            "properties": {
              "authority": {
                "type": "object",
                "required": [
                  "delegationEdgeIds"
                ],
                "properties": {
                  "delegationEdgeIds": {
                    "type": "array",
                    "minItems": 1
                  }
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "reviewStatus": {
            "const": "COMPILATION_READY"
          }
        }
      },
      "then": {
        "properties": {
          "machineCandidate": {
            "const": true
          },
          "ambiguityStatus": {
            "enum": [
              "CLEAR",
              "RESOLVED"
            ]
          },
          "layer": {
            "enum": [
              "LEGAL_FLOOR",
              "POLICY_OVERLAY"
            ]
          }
        }
      }
    }
  ]
}
