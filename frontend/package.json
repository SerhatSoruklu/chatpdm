{
  "name": "@chatpdm/frontend",
  "version": "0.0.0",
  "description": "Angular landing shell for the ChatPDM workspace.",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --host 127.0.0.1 --port 4200",
    "build": "npm run generate:policy-surface && npm run generate:sitemap && ng build",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"scripts/**/*.ts\"",
    "generate:policy-surface": "node --experimental-strip-types scripts/generate-policy-surface.ts",
    "generate:sitemap": "node --experimental-strip-types scripts/generate-sitemap.ts",
    "validate:policy-cookies-truth": "node --experimental-strip-types scripts/verify-policy-cookies-truth.ts",
    "validate:policy-terms-truth": "node --experimental-strip-types scripts/verify-policy-terms-truth.ts",
    "validate:cookies-page-view-model": "node --experimental-strip-types scripts/verify-cookies-page-view-model.ts",
    "validate:terms-page-view-model": "node --experimental-strip-types scripts/verify-terms-page-view-model.ts",
    "validate:inspect-index-view-model": "node --experimental-strip-types scripts/verify-inspect-index-view-model.ts",
    "validate:policy-lifecycle-evidence": "node --experimental-strip-types scripts/verify-policy-lifecycle-evidence.ts",
    "validate:policy-surface-split": "npm run validate:policy-cookies-truth && npm run validate:policy-terms-truth && npm run validate:cookies-page-view-model && npm run validate:terms-page-view-model && npm run validate:inspect-index-view-model && npm run validate:policy-lifecycle-evidence && node --experimental-strip-types scripts/verify-policy-surface-split.ts",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:frontend": "node dist/frontend/server/server.mjs"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "overrides": {
    "@hono/node-server": "1.19.14",
    "hono": "4.12.14",
    "vite": "7.3.2"
  },
  "private": true,
  "packageManager": "npm@11.8.0",
  "dependencies": {
    "@angular/animations": "21.2.10",
    "@angular/cdk": "21.2.8",
    "@angular/common": "21.2.10",
    "@angular/compiler": "21.2.10",
    "@angular/core": "21.2.10",
    "@angular/forms": "21.2.10",
    "@angular/material": "21.2.8",
    "@angular/platform-browser": "21.2.10",
    "@angular/platform-server": "21.2.10",
    "@angular/router": "21.2.10",
    "@angular/ssr": "21.2.8",
    "apexcharts": "^5.10.6",
    "express": "^5.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "21.2.8",
    "@angular/cli": "21.2.8",
    "@angular/compiler-cli": "21.2.10",
    "@eslint/js": "^9.39.4",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "eslint": "^9.39.4",
    "globals": "^16.5.0",
    "typescript-eslint": "^8.59.0",
    "typescript": "~5.9.2",
    "vitest": "^4.1.5"
  }
}
