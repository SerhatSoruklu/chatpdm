{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "data/governance/truth-exception-register.schema.json",
  "title": "ChatPDM Truth Exception Register Entry",
  "description": "Schema for one non-empty line in data/governance/truth-exception-register.ndjson.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "entryId",
    "entryAction",
    "entryTimestamp",
    "exceptionId",
    "date",
    "requestedBy",
    "approvingAuthority",
    "affectedClass",
    "normalRequiredPath",
    "exceptionTaken",
    "reason",
    "expiry",
    "rollbackPlan",
    "postExceptionReviewRequired",
    "linkedVersions",
    "linkedEventIds"
  ],
  "properties": {
    "entryId": {
      "type": "string",
      "pattern": "^TEE-[0-9]{4}-[0-9]{6}$"
    },
    "entryAction": {
      "type": "string",
      "enum": [
        "OPENED",
        "AMENDED",
        "CLOSED",
        "EXPIRED",
        "SUPERSEDED",
        "REMANDED"
      ]
    },
    "entryTimestamp": {
      "type": "string",
      "format": "date-time",
      "description": "Append time for this immutable register line."
    },
    "exceptionId": {
      "type": "string",
      "pattern": "^TE-[0-9]{4}-[0-9]{6}$"
    },
    "date": {
      "type": "string",
      "format": "date-time",
      "description": "Original effective start time of the exception. Later lines for the same exceptionId keep this value."
    },
    "requestedBy": {
      "type": "string",
      "minLength": 1
    },
    "approvingAuthority": {
      "type": "string",
      "minLength": 1
    },
    "affectedClass": {
      "type": "string",
      "enum": [
        "A",
        "B",
        "C",
        "D"
      ]
    },
    "normalRequiredPath": {
      "type": "string",
      "minLength": 1
    },
    "exceptionTaken": {
      "type": "string",
      "minLength": 1
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "expiry": {
      "type": "string",
      "format": "date-time",
      "description": "Last valid moment for the exception authority described by this entry."
    },
    "rollbackPlan": {
      "type": "string",
      "minLength": 1
    },
    "postExceptionReviewRequired": {
      "type": "boolean"
    },
    "postExceptionReviewType": {
      "type": [
        "string",
        "null"
      ]
    },
    "postExceptionReviewOwner": {
      "type": [
        "string",
        "null"
      ]
    },
    "postExceptionReviewDue": {
      "type": [
        "string",
        "null"
      ]
    },
    "linkedVersions": {
      "$ref": "#/$defs/linkedVersions"
    },
    "linkedLifecycleState": {
      "type": "string",
      "minLength": 1
    },
    "linkedEventIds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^GE-[0-9]{4}-[0-9]{6}$"
      }
    },
    "linkedIncidentId": {
      "type": "string",
      "pattern": "^EI-[0-9]{4}-[0-9]{6}$"
    },
    "linkedChallengeId": {
      "type": "string",
      "pattern": "^GC-[0-9]{4}-[0-9]{6}$"
    },
    "supersedesEntryId": {
      "type": "string",
      "pattern": "^TEE-[0-9]{4}-[0-9]{6}$"
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {
    "linkedVersions": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "description": "Version scope for the exception. At least one version locator must be present and non-null.",
      "properties": {
        "conceptVersion": {
          "type": [
            "string",
            "number",
            "null"
          ]
        },
        "conceptSetVersion": {
          "type": [
            "string",
            "number",
            "null"
          ]
        },
        "contractVersion": {
          "type": [
            "string",
            "number",
            "null"
          ]
        },
        "matcherVersion": {
          "type": [
            "string",
            "number",
            "null"
          ]
        },
        "normalizerVersion": {
          "type": [
            "string",
            "number",
            "null"
          ]
        },
        "overlayManifestVersion": {
          "type": [
            "string",
            "number",
            "null"
          ]
        },
        "storeVersion": {
          "type": [
            "string",
            "number",
            "null"
          ]
        }
      },
      "anyOf": [
        {
          "required": [
            "conceptVersion"
          ],
          "properties": {
            "conceptVersion": {
              "type": [
                "string",
                "number"
              ]
            }
          }
        },
        {
          "required": [
            "conceptSetVersion"
          ],
          "properties": {
            "conceptSetVersion": {
              "type": [
                "string",
                "number"
              ]
            }
          }
        },
        {
          "required": [
            "contractVersion"
          ],
          "properties": {
            "contractVersion": {
              "type": [
                "string",
                "number"
              ]
            }
          }
        },
        {
          "required": [
            "matcherVersion"
          ],
          "properties": {
            "matcherVersion": {
              "type": [
                "string",
                "number"
              ]
            }
          }
        },
        {
          "required": [
            "normalizerVersion"
          ],
          "properties": {
            "normalizerVersion": {
              "type": [
                "string",
                "number"
              ]
            }
          }
        },
        {
          "required": [
            "overlayManifestVersion"
          ],
          "properties": {
            "overlayManifestVersion": {
              "type": [
                "string",
                "number"
              ]
            }
          }
        },
        {
          "required": [
            "storeVersion"
          ],
          "properties": {
            "storeVersion": {
              "type": [
                "string",
                "number"
              ]
            }
          }
        }
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "postExceptionReviewRequired": {
            "const": true
          }
        }
      },
      "then": {
        "required": [
          "postExceptionReviewType",
          "postExceptionReviewOwner",
          "postExceptionReviewDue"
        ],
        "properties": {
          "postExceptionReviewType": {
            "type": "string",
            "minLength": 1
          },
          "postExceptionReviewOwner": {
            "type": "string",
            "minLength": 1
          },
          "postExceptionReviewDue": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "entryAction": {
            "enum": [
              "AMENDED",
              "CLOSED",
              "EXPIRED",
              "SUPERSEDED",
              "REMANDED"
            ]
          }
        }
      },
      "then": {
        "required": [
          "supersedesEntryId"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "entryAction": {
            "const": "REMANDED"
          }
        }
      },
      "then": {
        "required": [
          "linkedChallengeId"
        ]
      }
    }
  ]
}
